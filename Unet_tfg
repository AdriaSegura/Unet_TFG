    "import os\n",
    "import glob\n",
    "from PIL import Image\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from skimage.measure import regionprops_table\n",
    "\n",
    "# --------------------------\n",
    "# Parámetros\n",
    "# --------------------------\n",
    "mask_dir = \"/kaggle/working/mask\"  # directorio de máscaras\n",
    "max_images = 50                     # número de imágenes a analizar\n",
    "crop_index_to_use = 0               # solo el primer crop\n",
    "n_channels = test_dataset[0][1].shape[0]  # canales por crop\n",
    "crop_h, crop_w = test_dataset[0][1].shape[1:3]\n",
    "\n",
    "# --------------------------\n",
    "# 1. Listar máscaras .tif\n",
    "# --------------------------\n",
    "mask_files = sorted(glob.glob(os.path.join(mask_dir, \"*.tif\")))\n",
    "if len(mask_files) == 0:\n",
    "    raise ValueError(f\"No se encontraron máscaras .tif en {mask_dir}\")\n",
    "\n",
    "# Usar hasta max_images\n",
    "mask_files = mask_files[:max_images]\n",
    "n_images = len(mask_files)\n",
    "print(f\"Se analizarán {n_images} imágenes y sus máscaras correspondientes (solo crop {crop_index_to_use}).\")\n",
    "\n",
    "# --------------------------\n",
    "# 2. Iterar y calcular métricas\n",
    "# --------------------------\n",
    "results = []\n",
    "\n",
    "for i, mask_path in enumerate(mask_files):\n",
    "    # 🔹 Cargar máscara\n",
    "    mask_img = Image.open(mask_path)\n",
    "    mask_img = mask_img.resize((crop_w, crop_h), resample=Image.NEAREST)\n",
    "    labeled_mask = (np.array(mask_img) > 0).astype(int)\n",
    "\n",
    "    # 🔹 Tomar solo el crop deseado\n",
    "    test_crop = test_dataset[crop_index_to_use][1].numpy()   # (C,H,W)\n",
    "    pred_crop = pred_seg[crop_index_to_use].numpy()          # (C,H,W)\n",
    "\n",
    "    for ch in range(n_channels):\n",
    "        test_seg_2d = test_crop[ch, :, :]\n",
    "        pred_seg_2d = pred_crop[ch, :, :]\n",
    "\n",
    "        props_gt = regionprops_table(\n",
    "            labeled_mask,\n",
    "            intensity_image=test_seg_2d,\n",
    "            properties=(\"label\",\"area\",\"intensity_mean\")\n",
    "        )\n",
    "        df_gt = pd.DataFrame(props_gt)\n",
    "\n",
    "        props_pred = regionprops_table(\n",
    "            labeled_mask,\n",
    "            intensity_image=pred_seg_2d,\n",
    "            properties=(\"label\",\"area\",\"intensity_mean\")\n",
    "        )\n",
    "        df_pred = pd.DataFrame(props_pred)\n",
    "\n",
    "        if df_gt.empty or df_pred.empty:\n",
    "            continue\n",
    "\n",
    "        df_compare = pd.DataFrame({\n",
    "            \"image_index\": i,\n",
    "            \"crop_index\": crop_index_to_use,\n",
    "            \"channel\": ch,\n",
    "            \"mean_intensity_gt\": df_gt[\"intensity_mean\"],\n",
    "            \"mean_intensity_pred\": df_pred[\"intensity_mean\"],\n",
    "        })\n",
    "        df_compare[\"squared_error\"] = (\n",
    "            df_compare[\"mean_intensity_gt\"] - df_compare[\"mean_intensity_pred\"]\n",
    "        ) ** 2\n",
    "\n",
    "        results.append(df_compare)\n",
    "\n",
