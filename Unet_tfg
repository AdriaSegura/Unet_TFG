    "sample = random.choice(files) #Selecciona una imatge aleatòria de la llista files\n",
    "name = sample.name #Guarda el nom de la imatge\n",
    "\n",
    "raw = tiff.imread(raw_dir / name) #Llegeix la imatge QPI del nom guardat\n",
    "labels = tiff.imread(labels_dir / name) #Llegeix la imatge corresponent però amb fluorescència \n",
    "mask = tiff.imread(mask_dir / name)#Llegeix el mask de la mateixa imatge \n",
