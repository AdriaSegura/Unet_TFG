    "import os\n",
    "import glob\n",
    "from PIL import Image\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from skimage.measure import regionprops_table\n",
    "\n",
    "# --------------------------\n",
    "# 1. Listar máscaras .tif\n",
    "# --------------------------\n",
    "mask_dir = \"/kaggle/working/mask\"\n",
    "mask_files = sorted(glob.glob(os.path.join(mask_dir, \"*.tif\")))\n",
    "\n",
    "if len(mask_files) == 0:\n",
    "    raise ValueError(f\"No se encontraron máscaras .tif en {mask_dir}\")\n",
    "\n",
    "print(f\"Se encontraron {len(mask_files)} máscaras .tif\")\n",
    "\n",
    "# --------------------------\n",
    "# 2. Ajustar al número de crops de test\n",
    "# --------------------------\n",
    "n_crops = len(test_dataset)\n",
    "if len(mask_files) != n_crops:\n",
    "    print(f\"⚠️ Número de máscaras ({len(mask_files)}) distinto de número de crops ({n_crops}).\")\n",
    "mask_files = mask_files[:n_crops]\n",
    "\n",
    "# --------------------------\n",
    "# 3. Iterar y calcular métricas\n",
    "# --------------------------\n",
    "results = []\n",
    "\n",
    "for i, mask_path in enumerate(mask_files):\n",
    "    # 🔹 Cargar máscara\n",
    "    mask_img = Image.open(mask_path)\n",
    "\n",
    "    # 🔹 Ajustar tamaño al crop\n",
    "    test_crop = test_dataset[i][1].numpy()   # (C,H,W)\n",
    "    pred_crop = pred_seg[i].numpy()          # (C,H,W)\n",
    "    crop_h, crop_w = test_crop.shape[1], test_crop.shape[2]\n",
    "\n",
    "    mask_img_resized = mask_img.resize((crop_w, crop_h), resample=Image.NEAREST)\n",
    "    labeled_mask = np.array(mask_img_resized)\n",
    "    labeled_mask = (labeled_mask > 0).astype(int)\n",
    "\n",
    "    n_channels = test_crop.shape[0]\n",
    "    for ch in range(n_channels):\n",
    "        test_seg_2d = test_crop[ch, :, :]\n",
    "        pred_seg_2d = pred_crop[ch, :, :]\n",
    "\n",
    "        props_gt = regionprops_table(\n",
    "            labeled_mask,\n",
    "            intensity_image=test_seg_2d,\n",
    "            properties=(\"label\",\"area\",\"intensity_mean\")\n",
    "        )\n",
    "        df_gt = pd.DataFrame(props_gt)\n",
    "\n",
    "        props_pred = regionprops_table(\n",
    "            labeled_mask,\n",
    "            intensity_image=pred_seg_2d,\n",
    "            properties=(\"label\",\"area\",\"intensity_mean\")\n",
    "        )\n",
    "        df_pred = pd.DataFrame(props_pred)\n",
    "\n",
    "        if df_gt.empty or df_pred.empty:\n",
    "            continue\n",
    "\n",
    "        df_compare = pd.DataFrame({\n",
    "            \"crop_index\": i,\n",
    "            \"channel\": ch,\n",
    "            \"mean_intensity_gt\": df_gt[\"intensity_mean\"],\n",
    "            \"mean_intensity_pred\": df_pred[\"intensity_mean\"],\n",
    "        })\n",
    "        df_compare[\"squared_error\"] = (\n",
    "            df_compare[\"mean_intensity_gt\"] - df_compare[\"mean_intensity_pred\"]\n",
    "        ) ** 2\n",
    "\n",
    "        results.append(df_compare)\n",
    "\n",
    "# --------------------------\n",
    "# 4. Resultados finales\n",
    "# --------------------------\n",
    "if results:\n",
    "    df_all = pd.concat(results, ignore_index=True)\n",
    "    print(df_all)\n",
    "    print(\"Mean squared error total:\", df_all[\"squared_error\"].mean())\n",
    "else:\n",
    "    print(\"No se procesaron regiones, revisa las máscaras o el orden de tus datos.\")"
