    "import random #Per seleccionar una imatge de manera aleatòria\n",
    "\n",
    "import matplotlib.pyplot as plt  #Per mostrar gràfics\n",
    "\n",
    "raw_dir = Path(\"/kaggle/working/raw\")\n",
    "labels_dir = Path(\"/kaggle/working/labels\")\n",
