    "            tiff.imwrite(\n",
    "                mask_dir / f\"{cond}_{i}_f{frame:04d}.tif\",\n",
    "                mask_stack[frame],\n",
    "            )\n",
    "\n",
    "        print(f\"Processed {cond} {i}\")"
