    "# Cálculo de intensidades usando máscaras\n",
    "# -----------------------------\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from skimage.measure import regionprops_table\n",
    "\n",
    "# 1️⃣ Convertir tensores PyTorch a numpy\n",
    "# test_seg: (C, H, W)\n",
    "# pred_seg: (N, C, H, W) si hay batch, aquí usamos la primera predicción para simplificar\n",
    "test_seg_np = test_seg.numpy()           # (2, 128, 128) según tu output\n",
    "pred_seg_np = pred_seg[0].numpy()       # (2, 128, 128) primera imagen del batch\n",
    "\n",
    "# 2️⃣ Seleccionar el canal que quieres analizar\n",
    "# Por ejemplo canal 0 (BLUE) o canal 1 (GREEN)\n",
    "test_seg_2d = test_seg_np[0, :, :]      # forma (128, 128)\n",
    "pred_seg_2d = pred_seg_np[0, :, :]      # forma (128, 128)\n",
    "\n",
    "# 3️⃣ Recortar la máscara original para que coincida con el crop de test\n",
    "# Ajusta y_start, x_start según la posición del crop que se pasó al modelo\n",
    "y_start, x_start = 0, 0   # si el crop está en la esquina superior izquierda\n",
    "mask_crop = mask[y_start:y_start+128, x_start:x_start+128]  # shape (128, 128)\n",
    "labeled_mask = mask_crop.astype(int)  # convertir a int\n",
    "\n",
    "# 4️⃣ Calcular propiedades para fluorescencia real\n",
    "props_gt = regionprops_table(\n",
    "    labeled_mask,\n",
    "    intensity_image=test_seg_2d,\n",
    "    properties=('label', 'area', 'intensity_mean')\n",
    ")\n",
    "df_gt = pd.DataFrame(props_gt)\n",
    "\n",
    "# 5️⃣ Calcular propiedades para fluorescencia predicha\n",
    "props_pred = regionprops_table(\n",
    "    labeled_mask,\n",
    "    intensity_image=pred_seg_2d,\n",
    "    properties=('label', 'area', 'intensity_mean')\n",
    ")\n",
    "df_pred = pd.DataFrame(props_pred)\n",
