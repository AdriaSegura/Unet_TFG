    "step = 50 #Interval de frames dels videos (.tiff) del que s'extreu una imatge\n",
    "\n",
    "#Creació de les rutes de les carpetes del dataset \n",
    "fluor_dir = Path(\"/kaggle/input/datasets/adriseguragmez/fluo-mask-qpi-tfg/Fluorescent\")\n",
    "#Ruta que conté els tiffs de la fluorescència (canals GREEN i BLUE)\n",
    "qpi_dir = Path(\"/kaggle/input/datasets/adriseguragmez/fluo-mask-qpi-tfg/QPI\")\n",
    "#Ruta que conté els tiffs de QPI\n",
    "masks_dir = Path(\"/kaggle/input/datasets/adriseguragmez/fluo-mask-qpi-tfg/Masks\")\n",
    "#Ruta que conté els tiffs de les masks\n",
    "\n",
    "base_output = Path(\"/kaggle/working\") #Establir la ruta del output\n",
    "\n",
    "raw_dir = base_output / \"raw\"\n",
    "labels_dir = base_output / \"labels\"\n",
    "mask_dir = base_output / \"mask\"\n",
    "#Establir 3 directoris dintre de la ruta del output on es guardaran els imatges generades\n",
    "\n",
    "raw_dir.mkdir(exist_ok=True)\n",
    "labels_dir.mkdir(exist_ok=True)\n",
    "mask_dir.mkdir(exist_ok=True)\n",
    "#Creació de les carpetes en cas de no existir dels 3 directoris de sortida de l'output \n",
    "\n",
    "\n",
    "conditions = [\"st\", \"do\", \"bp\"] #Establim les 3 condicions dels diferents tiffs\n",
    "\n",
    "for cond in conditions:\n",
    "    for i in range(1, 8): #For i in range de 1 a 8 perquè n'hi han 7 tiffs totals per condició\n",
    "        green_path = fluor_dir / f\"GREEN_PNT1A_{cond}_{i}.tif\"\n",
    "        blue_path = fluor_dir / f\"BLUE_PNT1A_{cond}_{i}.tif\"\n",
    "        qpi_path = qpi_dir / f\"QPI_PNT1A_{cond}_{i}.tif\"\n",
    "        mask_path = masks_dir / f\"mask_PNT1A_{cond}_{i}.tif\"\n",
    "        #Establir les rutes de cada experiment (fluorescència BLUE/GREEN, QPI i màscares)\n",
    "        \n",
    "        if not (green_path.exists() and blue_path.exists()\n",
    "                and qpi_path.exists() and mask_path.exists()):\n",
    "            print(f\"Skipping {cond} {i} (missing files)\")\n",
    "            continue # Comprova que tots el tiffs de cada experiment existeixen \n",
    "\n",
    "        green_stack = tiff.imread(green_path)\n",
    "        blue_stack = tiff.imread(blue_path)\n",
    "        qpi_stack = tiff.imread(qpi_path)\n",
    "        mask_stack = tiff.imread(mask_path)\n",
    "        #Lectura en forma de stack (z, height, width) dels arxius tiff de les rutes creades per cada experiment\n",
    "\n",
    "        n_green = len(green_stack)\n",
    "        n_blue = len(blue_stack)\n",
    "        n_qpi = len(qpi_stack)\n",
    "        n_mask = len(mask_stack)\n",
    "        #Obtenció del nombre de frames per cada tiff de cada condició\n",
    "        \n",
    "        if not (n_green == n_blue == n_qpi == n_mask):\n",
    "            print(\n",
    "                f\"WARNING: Length mismatch in {cond} {i} → \"\n",
    "                f\"GREEN={n_green}, BLUE={n_blue}, QPI={n_qpi}, MASK={n_mask}\"\n",
    "            )\n",
    "            continue #Comprova que tots els tiffs en ordre de cada experiment tenen el mateix nombre de frames\n",
    "\n",
    "        n_frames = n_green\n",
    "        \n",
    "        \n",
    "        for frame in range(0, n_frames, step): \n",
    "        #Creem un bucle on llegim cada tiff des del primer frame fins l'últim, \n",
    "        #prenent només un de cada 50 (step) per no repetir imatges gaire semblants\n",
