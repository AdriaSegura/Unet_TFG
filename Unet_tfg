    "import deeptrack as dt\n",
    "\n",
    "raw_dir = \"/kaggle/working/raw\"\n",
    "labels_dir = \"/kaggle/working/labels\"\n",
    "\n",
    "raw_paths = dt.sources.ImageFolder(root=raw_dir) #Llegeix totes les imatges QPI\n",
    "fluo_paths = dt.sources.ImageFolder(root=labels_dir) #Llegeix totes les imatges de fluorescència\n",
    "paths = dt.sources.Source(raw=raw_paths, label=fluo_paths) #Associa cada imatge QPI amb la seva imatge de fluorescència corresponent\n",
    "train_paths, val_paths, test_paths = \\\n",
    "    dt.sources.random_split(paths, [0.8, 0.1, 0.1]) #Separa el dataset en entrenament (80%), validació (10%) i test (10%)\n",
    "\n",
    "train_srcs = train_paths.product(crop=[True] * 4, flip_ud=[True, False], flip_lr=[True, False])\n",
    "#Permet la modificació de les imatges d'entrenament: les retalla 4 vegades i les gira verticalment i horitzontalment\n",
    "val_srcs = val_paths.constants(crop=[False], flip_ud=False, flip_lr=False)\n",
    "#No permet la modificació de les imatges de validació, ni retalls ni girs per avaluar correctament el model\n",
    "test_srcs = test_paths.constants(crop=[False], flip_ud=False, flip_lr=False)\n",
    "#No permet la modificació de les imatges del test, ni retalls ni girs per avaluar correctament el model\n",
    "sources = dt.sources.Join(train_srcs, val_srcs, test_srcs) \n",
    "#Combina train, validation i test en un sol objecte"
