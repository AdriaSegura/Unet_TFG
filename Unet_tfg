    "#i la funció de pèrdua MSE per mesurar l'error entre la predicció i la fluorescència real\n",
    "\n",
    "unet_reg = unet_reg_template.create() #Genera el model final  de la unet a partir del Regressor\n",
    "\n",
    "print(unet_reg)"
